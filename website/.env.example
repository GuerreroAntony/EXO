# Supabase (cliente público — browser + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-only — NUNCA expor no client)
# Bypassa RLS, usado pelo webhook que não tem sessão de usuário
# Pega em: Supabase dashboard → Project settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — motor de IA dos agentes (Claude Haiku 4.5)
# Pega em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# WhatsApp Cloud API (app "EXO agents")
# App Secret: developers.facebook.com/apps/<app-id>/settings/basic — clica em "Show"
WHATSAPP_APP_SECRET=

# Token permanente do System User exoagentsbackend
# Local: ~/.exo-secrets/whatsapp-token.txt — cat $_ pra ver
# Prod: setar como env var no Vercel (Project Settings → Environment Variables)
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID e WABA ID do número de teste atual
WHATSAPP_PHONE_NUMBER_ID=1141756715678394
WHATSAPP_WABA_ID=1267435738837983

# Verify token do webhook — string aleatória que VOCÊ define.
# Gera com: openssl rand -hex 32
# Mesmo valor vai no painel Meta → Webhooks → "Verify token"
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Versão da Graph API (opcional, default v25.0)
# WHATSAPP_API_VERSION=v25.0
